# ---------------------------------------------------------------------------
# GymFlow — variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha com as chaves do seu projeto
# Supabase (Project Settings -> API). Sem elas, o app não inicia — este é um
# SaaS real, não há mais modo de demonstração com dados fictícios.
# ---------------------------------------------------------------------------

# URL do projeto Supabase (ex: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública "anon" (safe para o browser — protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave "service_role" (NUNCA exponha no client — usada apenas pelo script
# scripts/criar-academia.mjs, que roda no seu terminal/servidor)
SUPABASE_SERVICE_ROLE_KEY=

# E-mails separados por vírgula que podem acessar /admin (painel interno)
ADMIN_EMAILS=seu@email.com

# Domínio de produção fixo usado nos links compartilhados (QR de treino/feedback,
# link do app do aluno, webhooks). Defina com a URL canônica do site — assim o
# QR nunca aponta para uma URL de deploy/preview efêmera da Vercel.
# Ex: https://gestacad.com.br  ou  https://seu-projeto.vercel.app
# Se ficar em branco, usa a origem atual do navegador (comportamento antigo).
NEXT_PUBLIC_SITE_URL=

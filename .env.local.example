# ---------------------------------------------------------------------------
# GymFlow — variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha com as chaves do seu projeto
# Supabase (Project Settings -> API).
# ---------------------------------------------------------------------------

# URL do projeto Supabase (ex: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública "anon" (safe para o browser — protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave "service_role" (NUNCA exponha no client — uso server-side apenas)
SUPABASE_SERVICE_ROLE_KEY=

# Quando "true", o app usa dados de demonstração (mock) e funciona sem
# um projeto Supabase configurado. Deixe "false" em produção.
NEXT_PUBLIC_USE_MOCK=true
